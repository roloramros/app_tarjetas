<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvCardName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/card_name_placeholder"
            android:textAppearance="?attr/textAppearanceHeadline6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvCardNumber" />

        <ImageView
            android:id="@+id/ivCardIcon"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:scaleType="fitCenter"
            android:alpha="0.4"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="@string/card_icon_description" />

        <TextView
            android:id="@+id/tvCardNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/card_number_placeholder"
            android:textAppearance="?attr/textAppearanceBody1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvCardName"
            app:layout_constraintBottom_toBottomOf="@id/tvCardName" />

        <TextView
            android:id="@+id/tvSaldoTarjeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/saldo_tarjeta_label"
            android:textAppearance="?attr/textAppearanceBody2"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCardName" />

        <TextView
            android:id="@+id/tvExtraccionDisponible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/extraccion_disponible_label"
            android:textAppearance="?attr/textAppearanceBody2"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSaldoTarjeta" />

        <TextView
            android:id="@+id/tvDepositoDisponible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/deposito_disponible_label"
            android:textAppearance="?attr/textAppearanceBody2"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvExtraccionDisponible" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
